# Copy to .env and fill in. EXPO_PUBLIC_* vars are bundled into the app —
# ONLY the Supabase anon key belongs here (RLS is the perimeter).
# OPENAI_KEY and any service-role keys live in Supabase Edge Function secrets, never in this file.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_CHAIN=ethereum-sepolia
EXPO_PUBLIC_EVM_RPC_URL=https://ethereum-sepolia-rpc.example
EXPO_PUBLIC_EVM_CHAIN_ID=11155111
EXPO_PUBLIC_USDT_CONTRACT_ADDRESS=
EXPO_PUBLIC_USDT_DECIMALS=6
